include LICENSE.md
include README.md
include .gitignore
include pyproject.toml
recursive-include baselines *.json *.md
recursive-include data *.dat *.md
recursive-include docs *.md
recursive-include fortran *.f *.INC *.md
recursive-include scripts *.py *.md
recursive-include tests *.py *.md
recursive-include vendor *
global-exclude __pycache__ *.py[cod] *.o *.a *.so *.dylib *.exe *.lib
